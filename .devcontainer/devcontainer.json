{
  "name": "Clinical Intelligence Platform",

  "image": "mcr.microsoft.com/devcontainers/universal:2",

  "features": {
    "ghcr.io/devcontainers/features/flutter:1": {
      "channel": "stable"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.flutter",
        "Dart-Code.dart-code",
        "ms-python.python"
      ]
    }
  },

  "postCreateCommand": "cd frontend && flutter pub get"
}
