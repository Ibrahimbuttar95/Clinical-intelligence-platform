# Application Settings
SECRET_KEY=your-secret-key-change-in-production
ENVIRONMENT=development
DEBUG=false

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/clinical_db

# Redis Configuration (for caching and Celery)
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Payment Gateways - PayFast
PAYFAST_MERCHANT_ID=your_payfast_merchant_id
PAYFAST_SECRET=your_payfast_secret

# Payment Gateways - JazzCash
JAZZCASH_MERCHANT_ID=your_jazzcash_merchant_id
JAZZCASH_PASSWORD=your_jazzcash_password

# Payment Gateways - EasyPaisa
EASYPAISA_STORE_ID=your_easypaisa_store_id
EASYPAISA_HASH_KEY=your_easypaisa_hash_key

# Payment Gateways - Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
